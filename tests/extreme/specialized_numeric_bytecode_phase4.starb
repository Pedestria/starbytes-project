decl counts:Int[] = [1,2,3]
counts[2] = counts[0] + counts[1]

decl values:Float[] = [1.5,2.0,3.0]
decl i:Int = 0
decl countSum:Int = 0
decl sum:Float = 0.0

while(i < counts.length){
    countSum += counts[i]
    i += 1
}

i = 0
while(i < values.length){
    sum += values[i] * values[i]
    i += 1
}

values[1] = Float(values[1] + 1.0)
decl root:Double = sqrt(sum)

if(countSum == 6
   && sum > 15.24
   && sum < 15.26
   && values[1] == 3.0
   && root > 3.90
   && root < 3.91){
    print("NUMERIC-BYTECODE-PHASE4-OK")
}
else {
    print("NUMERIC-BYTECODE-PHASE4-FAIL")
    print(countSum)
    print(sum)
    print(values[1])
    print(root)
}
