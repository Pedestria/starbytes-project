#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
MAIN_SCRIPT="$REPO_ROOT/tools/starbpkg/main.starb"

DEFAULT_BUILD_DIR="${STARBYTES_BUILD_DIR:-$REPO_ROOT/build}"
STARBYTES_BIN="${STARBYTES_BIN:-$DEFAULT_BUILD_DIR/bin/starbytes}"
if [[ ! -x "$STARBYTES_BIN" && -x "${STARBYTES_BIN}.exe" ]]; then
  STARBYTES_BIN="${STARBYTES_BIN}.exe"
fi

fail() {
  echo "starbpkg: $*" >&2
  exit 1
}

FORWARDED_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -B|--starbytes-bin)
      shift
      [[ $# -gt 0 ]] || fail "missing value for --starbytes-bin"
      STARBYTES_BIN="$1"
      shift
      ;;
    -C|--project)
      FORWARDED_ARGS+=("$1")
      shift
      [[ $# -gt 0 ]] || fail "missing value for --project"
      FORWARDED_ARGS+=("$1")
      shift
      ;;
    -h|--help|-V|--verbose)
      FORWARDED_ARGS+=("$1")
      shift
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        FORWARDED_ARGS+=("$1")
        shift
      done
      break
      ;;
    *)
      while [[ $# -gt 0 ]]; do
        FORWARDED_ARGS+=("$1")
        shift
      done
      break
      ;;
  esac
done

if [[ ! -x "$STARBYTES_BIN" ]]; then
  fail "starbytes binary is not executable: $STARBYTES_BIN"
fi

if [[ ! -f "$MAIN_SCRIPT" ]]; then
  fail "missing core script: $MAIN_SCRIPT"
fi

set +e
RAW_OUTPUT="$("$STARBYTES_BIN" run "$MAIN_SCRIPT" -- "${FORWARDED_ARGS[@]}" 2>&1)"
STATUS=$?
set -e

SANITIZED_OUTPUT="$RAW_OUTPUT"
if [[ -n "$RAW_OUTPUT" ]] && command -v sed >/dev/null 2>&1; then
  SANITIZED_OUTPUT="$(printf '%s\n' "$RAW_OUTPUT" | sed -E $'s/\x1B\\[[0-9;]*m//g')"
fi

USER_LINES=()
FINAL_STATUS=$STATUS

if [[ -n "$SANITIZED_OUTPUT" ]]; then
  while IFS= read -r line; do
    if [[ "$line" == "Interp Starting" ]]; then
      continue
    fi

    if [[ "$line" == \"*\" ]]; then
      line="${line#\"}"
      line="${line%\"}"
    fi

    case "$line" in
      STARBPKG_EXIT:0)
        FINAL_STATUS=0
        ;;
      STARBPKG_EXIT:1)
        FINAL_STATUS=1
        ;;
      STARBPKG_TEXT:*)
        USER_LINES+=("${line#STARBPKG_TEXT:}")
        ;;
      *)
        USER_LINES+=("$line")
        ;;
    esac
  done <<< "$SANITIZED_OUTPUT"
fi

if [[ $FINAL_STATUS -eq 0 ]]; then
  for line in "${USER_LINES[@]}"; do
    printf '%s\n' "$line"
  done
else
  for line in "${USER_LINES[@]}"; do
    printf '%s\n' "$line" >&2
  done
fi

exit "$FINAL_STATUS"
