{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "starbytes://benchmark/track_a_summary.schema.json",
  "title": "Starbytes Track A Summary",
  "type": "object",
  "required": [
    "schema_version",
    "generated_utc",
    "phase",
    "track",
    "mode",
    "commit",
    "inputs",
    "host",
    "workloads"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_utc": { "type": "string" },
    "phase": { "type": "integer" },
    "track": { "type": "string" },
    "mode": { "type": "string", "enum": ["ttfr", "steady-state"] },
    "commit": { "type": "string" },
    "contracts": { "type": "string" },
    "inputs": { "type": "object" },
    "host": { "type": "object" },
    "starbytes_rel_python_geomean": { "type": "number" },
    "workloads": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["workload", "raw_file", "results"],
        "properties": {
          "workload": { "type": "string" },
          "raw_file": { "type": "string" },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["language", "mean_s", "stddev_s", "median_s", "runs"],
              "properties": {
                "language": { "type": "string" },
                "mean_s": { "type": "number" },
                "stddev_s": { "type": "number" },
                "median_s": { "type": "number" },
                "min_s": { "type": "number" },
                "max_s": { "type": "number" },
                "runtime_rel_python": { "type": "number" },
                "runs": { "type": "integer" }
              }
            }
          }
        }
      }
    }
  }
}
