import Random
import Crypto
import Compression
import Archive

secure(decl randomNeg = Random.secureBytes(-1)) catch (error:String) {
    print("PH3-RANDOM-NEG-BYTES-CATCH")
    print(error)
}
secure(decl randomNegHex = Random.secureHex(-4)) catch (error:String) {
    print("PH3-RANDOM-NEG-HEX-CATCH")
    print(error)
}

secure(decl badKdfSalt = Crypto.pbkdf2Sha256Hex("password","abc",1000,16)) catch (error:String) {
    print("PH3-CRYPTO-BAD-SALT-CATCH")
    print(error)
}
secure(decl badKdfIter = Crypto.pbkdf2Sha256Hex("password","73616c74",0,16)) catch (error:String) {
    print("PH3-CRYPTO-BAD-ITER-CATCH")
    print(error)
}

decl badHexCompare = Crypto.constantTimeHexEquals("zz","00")
if(badHexCompare == false){
    print("PH3-CRYPTO-BAD-HEX-BOOL-OK")
}
else {
    print("PH3-CRYPTO-BAD-HEX-BOOL-BAD")
}

secure(decl badDeflate = Compression.deflateHex("zz",6)) catch (error:String) {
    print("PH3-COMP-BAD-HEX-CATCH")
    print(error)
}
secure(decl badInflate = Compression.inflateHex("00010203")) catch (error:String) {
    print("PH3-COMP-BAD-INFLATE-CATCH")
    print(error)
}
secure(decl badGunzip = Compression.gunzipText("1f8b")) catch (error:String) {
    print("PH3-COMP-BAD-GUNZIP-CATCH")
    print(error)
}

decl invalidEntries:Dict = {"a":1}
secure(decl badPack = Archive.packTextMapHex(invalidEntries,true)) catch (error:String) {
    print("PH3-ARCHIVE-BAD-PACK-CATCH")
    print(error)
}
secure(decl badUnpack = Archive.unpackTextMapHex("00")) catch (error:String) {
    print("PH3-ARCHIVE-BAD-UNPACK-CATCH")
    print(error)
}
secure(decl badList = Archive.listEntries("00")) catch (error:String) {
    print("PH3-ARCHIVE-BAD-LIST-CATCH")
    print(error)
}

decl validCheck = Archive.isValid("00")
if(validCheck == false){
    print("PH3-ARCHIVE-ISVALID-OK")
}
else {
    print("PH3-ARCHIVE-ISVALID-BAD")
}

print("PH3-INVALID-CASE-OK")
