import Unicode

secure(decl loc = Unicode.localeCurrent()) catch {
    print("UNICODE-LOC-CATCH")
}
print(loc.id())

secure(decl rootLoc = Unicode.localeRoot()) catch {
    print("UNICODE-ROOT-CATCH")
}
print(rootLoc.id())

secure(decl folded = Unicode.caseFold("Straße")) catch {
    print("UNICODE-FOLD-CATCH")
}
print(folded)
if(folded == "straße" || folded == "strasse"){
    print("UNICODE-FOLD-OK")
}
else {
    print("UNICODE-FOLD-BAD")
}

secure(decl contains = Unicode.containsFolded("StarBytes","star",loc)) catch {
    print("UNICODE-CONTAINS-CATCH")
}
if(contains){
    print("UNICODE-CONTAINS-OK")
}
else {
    print("UNICODE-CONTAINS-BAD")
}

secure(decl starts = Unicode.startsWithFolded("StarBytes","star",loc)) catch {
    print("UNICODE-STARTS-CATCH")
}
secure(decl ends = Unicode.endsWithFolded("StarBytes","BYTES",loc)) catch {
    print("UNICODE-ENDS-CATCH")
}
secure(decl norm = Unicode.isNormalized("abc",0)) catch {
    print("UNICODE-ISNORM-CATCH")
}

secure(decl containsRoot = Unicode.containsFolded("Straße","STR",rootLoc)) catch {
    print("UNICODE-CONTAINS-ROOT-CATCH")
}
if(containsRoot){
    print("UNICODE-CONTAINS-ROOT-OK")
}
else {
    print("UNICODE-CONTAINS-ROOT-BAD")
}

secure(decl badNorm = Unicode.isNormalized("abc",99)) catch {
    print("UNICODE-ISNORM-BADFORM-CATCH")
}
secure(decl badLocale = Unicode.localeFrom("")) catch {
    print("UNICODE-LOCALE-BAD-CATCH")
}

if(starts && ends && norm){
    print("UNICODE-ADVANCED-OK")
}
else {
    print("UNICODE-ADVANCED-BAD")
}

print("UNICODE-ADVANCED-STABILITY-OK")
