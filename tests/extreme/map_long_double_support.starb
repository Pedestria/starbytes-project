decl counts:Map<String,Long> = {"alpha":1,"beta":2}
counts.set("gamma",3)
counts["beta"] = 6

decl hasAlpha:Bool = counts.has("alpha")
decl keys:Array<String> = counts.keys()
decl vals:Array<Long> = counts.values()
decl copied:Map<String,Long> = counts.copy()
decl asDict:Dict = counts

decl pi:Double = 3.25
decl big:Long = 900000
decl castedLong = Long(12.0)
decl castedDouble = Double("4.5")
decl piPlus = pi + 1.0
decl bigPlus = big + 1

if(hasAlpha
   && keys.length == 3
   && vals.length == 3
   && copied.length == 3
   && asDict.length == 3
   && pi is Double
   && big is Long
   && castedLong is Long
   && castedDouble is Double
   && piPlus == 4.25
   && bigPlus == 900001){
    print("MAP-LONG-DOUBLE-OK")
}
