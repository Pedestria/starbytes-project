import CmdLine

print(CmdLine.executablePath())
print(CmdLine.scriptPath())
print(CmdLine.argCount())
print(CmdLine.rawArgs())
print(CmdLine.hasFlag("verbose",["v"]))
print(CmdLine.flagValue("config",["c"]))
print(CmdLine.flagValues("tag",["t"]))
print(CmdLine.positionals())
print("CMDLINE-MODULE-OK")
